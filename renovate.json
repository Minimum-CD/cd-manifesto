{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "timezone": "America/Chicago",
  "schedule": ["after 9pm on sunday"],
  "minimumReleaseAge": "7 days",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "postUpdateOptions": ["gomodTidy"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "packageRules": [
    {
      "description": "Dev dependency patch + minor: automerge after the cooldown",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "dev dependencies (non-breaking)",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "labels": ["dependencies", "automerge"]
    },
    {
      "description": "Runtime dependency patch: lower risk, automerge after the cooldown",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["patch"],
      "groupName": "runtime patches",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "labels": ["dependencies", "automerge"]
    },
    {
      "description": "Runtime minor updates: grouped for human review",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["minor"],
      "groupName": "runtime minor updates",
      "automerge": false,
      "labels": ["dependencies", "review-required"]
    },
    {
      "description": "Major updates always get their own PR and must be reviewed",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "breaking-change"]
    },
    {
      "description": "GitHub Actions: keep updated; group non-major and automerge after the cooldown",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "github actions",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "labels": ["dependencies", "github-actions", "automerge"]
    },
    {
      "description": "Go modules: enable indirect (Hugo module) deps so everything in go.mod is tracked",
      "matchManagers": ["gomod"],
      "matchDepTypes": ["indirect"],
      "enabled": true
    },
    {
      "description": "Go modules: group minor + patch updates for human review",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "go modules",
      "automerge": false,
      "labels": ["dependencies", "go"]
    },
    {
      "description": "Security updates are surfaced and reviewed; cooldown retained (no bypass)",
      "matchCategories": ["security"],
      "automerge": false,
      "labels": ["security"]
    },
    {
      "description": "Renovate itself: review, never automerge",
      "matchPackageNames": ["renovate"],
      "automerge": false,
      "labels": ["dependencies", "review-required"]
    }
  ]
}
